# ====================================
# 4dt907 - Environment Configuration
# ====================================
# Copy this file to .env and fill in the values
# The .env file should be placed at the project root

# ====================================
# Backend Configuration
# ====================================
# Port for the backend API (used in Docker development)
BACKEND_PORT=8080

# ====================================
# Frontend Configuration
# ====================================
# Port for the frontend (used in Docker development)
FRONTEND_PORT=3030

# Backend URL (optional, for external backend hosting)
# Leave empty for local Docker development (uses Vite dev-server proxy).
# Set to your Render service URL when deploying frontend on Vercel + backend on Render.
# Example: https://4dt907-backend.onrender.com
BACKEND_URL=        # Leave blank for local Docker dev; set to external backend URL only when needed

# Build-time backend URL injected into the static frontend bundle (VITE_ prefix required).
# - Full-Vercel deployment: leave empty (frontend uses relative /api/* paths).
# - Vercel (frontend) + Render (backend): set to your Render service URL.
#   This is set in the Vercel project's Environment Variables, NOT in .env.
#   Example: https://4dt907-backend.onrender.com
VITE_BACKEND_URL=

# ====================================
# Supabase Configuration
# ====================================
# Project URL — found in your Supabase project under Settings > API.
# Example: https://xyzcompany.supabase.co
VITE_SUPABASE_URL=

# Anon (public) API key — safe to expose in the browser bundle.
# Found in your Supabase project under Settings > API > Project API keys.
VITE_SUPABASE_ANON_KEY=

# Required Supabase table (run once in the Supabase SQL editor):
#
#   CREATE TABLE squat_sessions (
#       id             SERIAL PRIMARY KEY,
#       id_name        VARCHAR(255),
#       raw_keypoints  JSONB NOT NULL,
#       score          FLOAT,
#       classification TEXT,
#       created_at     TIMESTAMP DEFAULT CURRENT_TIMESTAMP
#   );
#
# raw_keypoints structure stored by the frontend:
#   {
#     "2d": [ [x, y], … ],    -- one [x, y] pair per squat keypoint
#     "3d": [ [x, y, z], … ]  -- one [x, y, z] triple per squat keypoint
#   }
#
# Optional: enable Row Level Security and allow inserts from the anon role:
#
#   ALTER TABLE squat_sessions ENABLE ROW LEVEL SECURITY;
#   CREATE POLICY "allow anon insert"
#       ON squat_sessions FOR INSERT TO anon WITH CHECK (true);

# ====================================
# Vercel Deployment (Optional)
# ====================================
# These are automatically set by Vercel in production
# VERCEL_URL - Automatically provided by Vercel
# For custom domains, set this:
# NOTE: No trailing "/"
PRODUCTION_URL=     # Leave blank unless you know what you are doing

# ====================================
# MLflow Configuration
# ====================================
# MLflow tracking server URI
# Example: https://dagshub.com/your-username/4dt907.mlflow
MLFLOW_TRACKING_URI=

# ====================================
# Model URIs - Assignment 2
# ====================================
# Production model URI
# Example: models:/YourModel@prod or runs:/run-id/model
MODEL_URI_PROD=

# Development model URI
MODEL_URI_DEV=

# Backup model URI
MODEL_URI_BACKUP=

# ====================================
# Model URIs - Assignment 3 (Weakest Link)
# ====================================
# Weakest Link production model URI
WEAKLINK_MODEL_URI_PROD=

# Weakest Link development model URI
WEAKLINK_MODEL_URI_DEV=

# Weakest Link backup model URI
WEAKLINK_MODEL_URI_BACKUP=

# ====================================
# Notes
# ====================================
# 1. For local Docker development:
#    - Set BACKEND_PORT and FRONTEND_PORT
#    - Set MLFLOW_TRACKING_URI and model URIs
#
# 2. For Vercel (frontend) + Render (backend) — primary strategy:
#    - Set MLFLOW_TRACKING_URI and model URIs in the Render dashboard
#    - Set PRODUCTION_URL to your Vercel frontend URL in the Render dashboard (for CORS)
#    - Set VITE_BACKEND_URL to your Render service URL in the Vercel dashboard
#    - See DEPLOYMENT.md for full step-by-step instructions
#
# 3. For a full-Vercel deployment (frontend + serverless backend):
#    - Set MLFLOW_TRACKING_URI and model URIs in the Vercel dashboard
#    - VERCEL_URL is automatically provided by Vercel
#    - Leave VITE_BACKEND_URL empty (frontend uses relative /api/* paths)
#    - Restore the Python build entry in vercel.json (see DEPLOYMENT.md)