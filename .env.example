# ====================================
# 4dt907 - Environment Configuration
# ====================================
# Copy this file to .env and fill in the values.
# Place the .env at the project root (next to this file).
#
# Variable scoping rules:
#   - Variables WITHOUT a "VITE_" prefix are server-side only (Python backend
#     or Vite dev-server). They are never embedded in the browser bundle.
#   - Variables WITH a "VITE_" prefix are injected into the browser bundle at
#     build time by Vite. Only use this prefix for values that are safe to
#     expose publicly (e.g. anon keys, public URLs).

# ====================================
# Backend Configuration
# ====================================

# TCP port the FastAPI backend listens on inside Docker.
# Referenced by: src/docker-compose.yml (container port mapping),
#                src/backend/app/main.py (HOST_PORT fallback = 8080),
#                vite.config.js (Vite proxy target when BACKEND_URL is unset).
BACKEND_PORT=8080

# ====================================
# Frontend Configuration
# ====================================

# TCP port the Vite dev-server / frontend container listens on.
# Referenced by: src/docker-compose.yml (host port mapping),
#                src/frontend/vite.config.js (server.port, fallback = 3030).
FRONTEND_PORT=3030

# Runtime backend URL used by the Vite dev-server proxy (server-side only).
# The Vite proxy forwards every /api/* request to this target so the browser
# never needs to know the backend origin during local development.
#   - Leave EMPTY for local Docker development — the proxy will use
#     http://localhost:<BACKEND_PORT> automatically.
#   - Set to an external URL (e.g. https://fourdt907-backend.onrender.com) only
#     when you want the local dev-server to proxy to a remote backend instead
#     of the local Docker container.
# Referenced by: src/frontend/vite.config.js (proxy.target).
# Should have same value as VITE_BACKEND_URL
BACKEND_URL=

# Build-time backend URL embedded into the static frontend bundle.
# Prefixed with VITE_ so Vite exposes it to browser code via import.meta.env.
#   - Set to your Render service URL for the split hosting deployment so the
#     browser knows where to send API requests.
#     Example: https://fourdt907-backend.onrender.com
#   - Set this in the Vercel project dashboard under Settings > Environment
#     Variables, NOT in this .env file (which is only used locally).
# Referenced by: src/frontend/src/apiBase.js (BASE constant).
# Should have the same value as BACKEND_URL (e.g. https://yourapp.onrender.com).
VITE_BACKEND_URL=

# ====================================
# Vercel Deployment (Optional)
# ====================================

# Your custom frontend domain, without a trailing slash.
# Added to the FastAPI CORS allowed-origins list so the Render backend accepts
# requests that originate from this URL.
# Set this in the Render dashboard (not Vercel) so the backend knows the origin.
#   Example: https://4dt907.vercel.app
# Referenced by: src/backend/app/main.py (ALLOWED_ORIGINS).
PRODUCTION_URL=

# ====================================
# Supabase Configuration
# ====================================
# Both variables require the VITE_ prefix because they are read directly by
# the React frontend running in the browser (src/frontend/src/supabaseClient.js).
# The anon key is intentionally public — it carries no special privileges and
# Row Level Security (RLS) policies control what it can access.
# If either variable is left empty the Supabase client will not be created,
# the name input will be hidden, and no database writes will occur.

# Project URL — found in your Supabase dashboard under Settings > API.
# Example: https://xyzcompany.supabase.co
VITE_SUPABASE_URL=

# Anon (public) API key — safe to expose in the browser bundle.
# Found in your Supabase dashboard under Settings > API > Project API keys.
# In SupaBase docs usually named: VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY
VITE_SUPABASE_ANON_KEY=

# Required Supabase table (run once in the Supabase SQL editor):
#
# RLS Row Level Security Enabled
#
#   CREATE TABLE squat_keypoints (
#       id             SERIAL PRIMARY KEY,
#       id_name        VARCHAR,                 -- nullable user-provided name
#       raw_keypoints  JSONB NOT NULL,          -- 3D keypoint array
#       score          FLOAT8,                  -- (0–1) by DL in future
#       classification VARCHAR,                 -- Classification by DL in future
#       created_at     TIMESTAMPTZ now()
#   );
#
# raw_keypoints structure stored by the frontend (3D only):
#   {
#     "3d": [ [x, y, z], … ]  -- one [x, y, z] triple per squat keypoint
#   }

# ====================================
# MLflow Configuration
# ====================================

# URI of the MLflow tracking server used to log experiments and register models.
# Required by the backend at startup for the Assignment 2 and Assignment 3 models.
# Without this, /api/v1/predict/* and /api/v1/weakest-link/* will fail to load.
#   Example (DagsHub): https://dagshub.com/your-username/4dt907.mlflow
#   Example (local):   http://localhost:5000
# Referenced by: src/backend/app/services/model_service.py,
#                src/backend/app/services/weaklink_model_service.py.
MLFLOW_TRACKING_URI=

# ====================================
# Model URIs - Assignment 2 (Predict Champion/Latest)
# ====================================
# These URIs point directly to a logged MLflow model artifact.
# Accepted formats:
#   runs:/<run-id>/model        — a specific MLflow run artifact
#   models:/<name>@<alias>      — a registered model alias  (e.g. models:/MyModel@champion)
#   models:/<name>/<version>    — a specific registered model version
# Referenced by: src/backend/app/services/model_service.py (_direct_uri_for_variant).

# URI for the production / champion model (variant: "champion", "best", "prod").
MODEL_URI_PROD=

# URI for the development / latest model (variant: "latest", "dev").
MODEL_URI_DEV=

# URI for the backup model (variant: "backup").
MODEL_URI_BACKUP=

# ====================================
# Model URIs - Assignment 3 (Weakest Link)
# ====================================
# Same URI format as the Assignment 2 variables above, but for the weakest-link
# model served at /api/v1/weakest-link/*.
# Referenced by: src/backend/app/services/weaklink_model_service.py (_direct_uri_for_variant).

# URI for the production weakest-link model (variant: "champion", "best", "prod").
WEAKLINK_MODEL_URI_PROD=

# URI for the development weakest-link model (variant: "latest", "dev").
WEAKLINK_MODEL_URI_DEV=

# URI for the backup weakest-link model (variant: "backup").
WEAKLINK_MODEL_URI_BACKUP=

# ====================================
# Model URIs - Z-predictor
# ====================================
# Same URI format as the Assignment 2 variables above, but for the Z-predictor

# URI for the production Z-predictor model (variant: "champion", "best", "prod").
Z_MODEL_URI_PROD=

# URI for the development Z-predictor model (variant: "latest", "dev").
Z_MODEL_URI_DEV=

# URI for the backup Z-predictor model (variant: "backup").
Z_MODEL_URI_BACKUP=

# ====================================
# Quick-start checklist
# ====================================
# 1. Local Docker development:
#    - Set BACKEND_PORT and FRONTEND_PORT (defaults are usually fine).
#    - Set MLFLOW_TRACKING_URI, MODEL_URI_* and WEAKLINK_MODEL_URI_*.
#    - Leave BACKEND_URL empty (Vite proxy resolves to localhost automatically).
#
# 2. Split hosting — Vercel (frontend) + Render (backend) + Supabase + DagsHub:
#    - In the Render dashboard: set MLFLOW_TRACKING_URI (DagsHub URI), MODEL_URI_*,
#      WEAKLINK_MODEL_URI_*, and PRODUCTION_URL (your Vercel frontend URL).
#    - In the Vercel dashboard: set VITE_BACKEND_URL to your Render service URL,
#      and VITE_SUPABASE_URL + VITE_SUPABASE_ANON_KEY for keypoint storage.
#    - See DEPLOYMENT.md for the full step-by-step guide.
